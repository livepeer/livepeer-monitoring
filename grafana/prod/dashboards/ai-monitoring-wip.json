          "targets": [
            {
              "datasource": {
                "type": "grafana-clickhouse-datasource",
                "uid": "cdrta4zbtlddsa"
              },
              "editorType": "sql",
              "format": 1,
              "meta": {
                "builderOptions": {
                  "columns": [],
                  "database": "",
                  "limit": 1000,
                  "mode": "list",
                  "queryType": "table",
                  "table": ""
                }
              },
              "pluginVersion": "4.7.0",
              "queryType": "table",
              "rawSql": "SELECT\ntoStartOfMinute(se.timestamp_ts) AS timestamp_ts,\nse.stream_id,\nss.state,\nsum(se.restart_count) AS Restart_Count,\ncountIf(se.sub_type = 'error') AS Error_Count\n\nFROM\nnetwork_events.stream_events AS se\nJOIN\nnetwork_events.stream_status AS ss ON se.stream_id = ss.stream_id\nWHERE\nse.stream_id IN (SELECT DISTINCT stream_id FROM network_events.stream_events)\nAND $__timeFilter(se.timestamp_ts)\nGROUP BY\ntimestamp_ts, se.stream_id, ss.state\nORDER BY\ntimestamp_ts ASC;",
              "refId": "A"
            }
          ],
          "title": "Stream Health",
          "type": "timeseries"
        }

              },
              "pluginVersion": "4.7.0",
              "queryType": "table",
              "rawSql": "SELECT \n    stream_id, \n    countIf(event_type = 'restart') AS restart_count,\n    countIf(event_type = 'error') AS error_count\nFROM (\n    SELECT DISTINCT stream_id\n    FROM network_events.stream_events\n    WHERE event_type IN ('restart', 'error')\n    ORDER BY timestamp_ts DESC\n    LIMIT 15\n) AS latest_streams\nJOIN network_events.stream_events USING (stream_id)\nGROUP BY stream_id\nORDER BY stream_id ASC;\n",
              "refId": "A"
            }
          ],
          "title": "Stream Status [Error/Restart Count with Stream ID]",
          "type": "table"
        },
        {
          "datasource": {
